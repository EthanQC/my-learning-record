{
  "name": "my-learning-record",
  "version": "1.0.0",
  "description": "个人学习记录与技术博客（Next.js + Go + MySQL），上线于 qingverse.com",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "start:web": "npm run start -w apps/web",
    "dev:api": "make -C apps/api dev",
    "dev": "npm-run-all -p dev:web dev:api",
    "fix:frontmatter": "node scripts/fix-frontmatter.js",
    "fix:frontmatter:dry": "node scripts/fix-frontmatter.js --dry"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EthanQC/my-learning-record.git"
  },
  "keywords": [],
  "author": "EthanQC",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/EthanQC/my-learning-record/issues"
  },
  "homepage": "https://github.com/EthanQC/my-learning-record#readme",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^24.10.0",
    "gray-matter": "^4.0.3",
    "npm-run-all": "^4.1.5"
  }
}
