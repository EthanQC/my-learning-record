{
  "name": "my-learning-record",
  "version": "1.0.0",
  "description": "Devline——双线个人技术博客（Next.js 静态站，Go API 代码仅归档保留），上线于 qingverse.com",
  "scripts": {
    "test": "npm run test -w apps/web",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "start:web": "npm run start -w apps/web",
    "dev": "npm run dev:web",
    "fix:frontmatter": "node scripts/fix-frontmatter.js",
    "fix:frontmatter:dry": "node scripts/fix-frontmatter.js --dry"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EthanQC/my-learning-record.git"
  },
  "keywords": [],
