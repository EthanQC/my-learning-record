# CI/CD 镜像仓库（GitHub Actions 会覆盖 WEB_TAG）
REGISTRY=your-registry.example.com/namespace
WEB_TAG=

# 域名（主站，Caddy 主块；多个用逗号，如需 www 同域证书）
DOMAIN=yourdomain.com, www.yourdomain.com
# 统计子域（GoatCounter，独立单值变量，不要写 stats.${DOMAIN}——见 Caddyfile.example 注释）
STATS_DOMAIN=stats.qingverse.com

# Web 构建/运行时站点地址（metadata、canonical、feed.xml 等使用）
NEXT_PUBLIC_SITE_URL=https://qingverse.com

# GoatCounter 镜像版本（固定版本，禁用 :latest 漂移；无默认值，必须显式设置，
# 否则 docker compose up 会因 image 引用为空报 invalid reference format）
GOATCOUNTER_TAG=2.7.0
