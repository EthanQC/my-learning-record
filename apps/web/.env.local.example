# apps/web 本地开发环境变量示例（cp .env.local.example .env.local 后按需填写）
# 注意：NEXT_PUBLIC_* 变量在构建期内联进静态产物；生产镜像要生效必须走
# Docker 构建参数（apps/web/Dockerfile 的 ARG + deploy.yml 的 build-args），
# compose 运行期注入对 SSG 页面无效。

# 站点正式域名（可留空：代码里有 https://qingverse.com 硬编码兜底，
# 见 src/app/layout.tsx 与 src/lib/site.ts）
NEXT_PUBLIC_SITE_URL=https://qingverse.com

# Google Search Console 验证串（meta 标签方式；留空则不渲染 verification meta）
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster 验证串（msvalidate.01；留空则不渲染）
NEXT_PUBLIC_BING_VERIFICATION=
